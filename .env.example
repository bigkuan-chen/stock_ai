# App
APP_TIMEZONE=Asia/Taipei
APP_LANGUAGE=zh-TW

# Default state
DEFAULT_POLICIES=[]
DEFAULT_INDUSTRIES=[]
DEFAULT_COMPANIES=[]

# Dashboard
TOP_INDUSTRIES_LIMIT=100
TOP_COMPANIES_LIMIT=300
RECENT_POLICIES_LIMIT=300

# Crawl
CRAWL_LOOKBACK_DAYS=20
CRAWL_REQUEST_TIMEOUT_SECONDS=200
CRAWL_USER_AGENT=PolicyResearchBot/1.0

# Sources
WHITE_HOUSE_BASE_URL=https://www.whitehouse.gov
FEDERAL_REGISTER_API_BASE_URL=https://www.federalregister.gov/api/v1

# Stock data
YFINANCE_LOOKUP_ENABLED=true
YFINANCE_LOOKUP_LIMIT=30
YFINANCE_REQUEST_TIMEOUT_SECONDS=5

# Optional future providers
AI_PROVIDER=none
AI_API_KEY=
